{
  "experiment_name": "hose_liquid_dynamic",
  "paths": {
    "project_root": ".",
    "dataset_dir": "dataset",
    "outputs_dir": "outputs",
    "logs_dir": "logs",
    "configs_dir": "configs"
  },
  "data": {
    "daily_file": "dataset/hose_liquid_100_strict_adclose_wide.csv",
    "target_file": "dataset/hose_liquid_100_strict_weekly_min_max_return.csv",
    "aggregation_mode": "weekly",
    "feature_set": "baseline4",
    "window_size": 8,
    "split_idx": -12
  },
  "graph": {
    "graph_mode": "dynamic",
    "sector_map_file": "dataset/hose_liquid_100_strict_sector_map.csv",
    "top_k": 5,
    "use_arm": false,
    "use_static_graph": false,
    "similarity_metric": "pearson",
    "corr_threshold": 0.55
  },
  "model": {
    "model_type": "deep",
    "in_features": 4,
    "gnn_hidden": 128,
    "lstm_hidden": 256,
    "num_layers": 1,
    "heads": 2,
    "dropout": 0.5
  },
  "loss": {
    "name": "correlation",
    "alpha": 0.5,
    "weight_mse": 0.45,
    "weight_corr": 0.45,
    "weight_penalty": 0.1
  },
  "training": {
    "epochs": 30,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "print_every": 1,
    "early_stopping_patience": 10,
    "warmup_epochs": 5,
    "min_delta": 0.0001,
    "use_scheduler": true
  },
  "runtime": {
    "random_seed": 42,
    "device": "auto",
    "save_checkpoint": true,
    "save_plots": true,
    "show_plots": false
  },
  "benchmark": {
    "output_dir": "logs",
    "protocol": "walk_forward",
    "seeds": [
      42,
      52,
      62
    ],
    "gnn_epochs": 80,
    "baseline_epochs": 80,
    "device": "auto",
    "n_folds": 5,
    "n_runs": 3,
    "include_statistical_models": true,
    "validation_split": 0.1,
    "early_stopping_patience": 8,
    "min_train_size": 150,
    "test_step": 15
  },
  "optuna": {
    "n_trials": 40,
    "direction": "minimize",
    "metric": "mae_interval",
    "study_name": "hose_liquid_dynamic",
    "storage_url": null,
    "persist_study": true,
    "resume_study": true,
    "sampler_seed": 42,
    "max_epochs_per_trial": 10,
    "prune_after_epochs": 5
  }
}